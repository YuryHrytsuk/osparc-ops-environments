{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["helpers:pinGitHubActionDigests"],
  "schedule": ["* 0-4 * * *"],
  "labels": ["renovate"],
  "minimumReleaseAge": "60 days",
  "dependencyDashboard": true,
  "enabledManagers": ["helmv3", "helmfile", "github-actions", "custom.regex"],
  "helmfile": {
    "managerFilePatterns": [
      "/(^|/)helmfile\\.ya?ml$/",
      "/(^|/)helmfile\\.simcore\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/Makefile$/",
        "/^\\.github/workflows/[^/]+\\.ya?ml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+?)(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*[\\r\\n]+\\s*[A-Za-z0-9_.-]+\\s*(?::=|:)\\s*[\"']?(?<currentValue>[^\"'\\s]+)"
      ]
    }
  ]
}
